page {
  min-height: 100vh;
  background: #f8eadb;
  color: #2b2520;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 34rpx 28rpx 56rpx;
  background: linear-gradient(180deg, #fff3e8 0%, #f8eadb 48%, #eef5ed 100%);
}

.section {
  margin-top: 28rpx;
}

.panel {
  box-sizing: border-box;
  padding: 28rpx;
  border: 1rpx solid #eadfd1;
  border-radius: 18rpx;
  background: #fffaf5;
  box-shadow: 0 10rpx 34rpx rgba(86, 61, 42, 0.08);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.25;
}

.subtitle {
  margin-top: 10rpx;
  color: #7b6b5b;
  font-size: 26rpx;
  line-height: 1.5;
}

.label {
  color: #8a7663;
  font-size: 24rpx;
}

.value {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
}

.button {
  height: 72rpx;
  margin: 0;
  padding: 0 26rpx;
  border-radius: 14rpx;
  background: #2f6f62;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 72rpx;
}

.button.secondary {
  border: 1rpx solid #2f6f62;
  background: #fffaf5;
  color: #2f6f62;
}

.button.soft {
  background: #d8785f;
}

.input,
.textarea {
  box-sizing: border-box;
  width: 100%;
  margin-top: 12rpx;
  padding: 20rpx;
  border: 1rpx solid #eadfd1;
  border-radius: 14rpx;
  background: #fffdf9;
  font-size: 28rpx;
}

.textarea {
  min-height: 180rpx;
}

.hero-panel {
  box-sizing: border-box;
  margin-top: 30rpx;
  padding: 34rpx;
  border: 1rpx solid #f0dccc;
  border-radius: 22rpx;
  background: #fffbf6;
  box-shadow: 0 12rpx 42rpx rgba(86, 61, 42, 0.09);
}

.hero-title {
  color: #2b2520;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.25;
}

.hero-note {
  margin-top: 14rpx;
  color: #755f4f;
  font-size: 26rpx;
  line-height: 1.55;
}

.pill {
  display: inline-flex;
  align-items: center;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #fffaf5;
  color: #9a654f;
  font-size: 24rpx;
  white-space: nowrap;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.quick-tile {
  box-sizing: border-box;
  min-height: 150rpx;
  padding: 24rpx;
  border: 1rpx solid #eadfd1;
  border-radius: 18rpx;
  background: #fffaf5;
  box-shadow: 0 8rpx 24rpx rgba(86, 61, 42, 0.06);
}

.quick-tile-title {
  color: #2b2520;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.3;
}

.quick-tile-text {
  margin-top: 12rpx;
  color: #7b6b5b;
  font-size: 24rpx;
  line-height: 1.45;
}
