page {
  min-height: 100vh;
  background: #f7f3ed;
  color: #25211d;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
}

.section {
  margin-top: 28rpx;
}

.panel {
  box-sizing: border-box;
  padding: 28rpx;
  border: 1rpx solid #e1d7ca;
  border-radius: 8rpx;
  background: #fffdfa;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.25;
}

.subtitle {
  margin-top: 10rpx;
  color: #766d62;
  font-size: 26rpx;
  line-height: 1.5;
}

.label {
  color: #766d62;
  font-size: 24rpx;
}

.value {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
}

.button {
  height: 72rpx;
  margin: 0;
  border-radius: 8rpx;
  background: #2f6f62;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 72rpx;
}

.button.secondary {
  border: 1rpx solid #2f6f62;
  background: transparent;
  color: #2f6f62;
}

.input,
.textarea {
  box-sizing: border-box;
  width: 100%;
  margin-top: 12rpx;
  padding: 20rpx;
  border: 1rpx solid #d8cec1;
  border-radius: 8rpx;
  background: #fffdfa;
  font-size: 28rpx;
}

.textarea {
  min-height: 180rpx;
}
