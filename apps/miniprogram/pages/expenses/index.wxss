.field-gap,
.action-gap {
  margin-top: 22rpx;
}

.summary-panel {
  background: linear-gradient(135deg, #fffaf5 0%, #f2f8ef 100%);
}

.summary-amount {
  margin-top: 8rpx;
  color: #2f6f62;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.15;
  overflow-wrap: anywhere;
}

.small-button {
  min-width: 128rpx;
  max-width: 168rpx;
  padding: 8rpx 12rpx;
  font-size: 24rpx;
}

.stats-block {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eadfd1;
}

.stats-block.compact {
  margin-top: 16rpx;
}

.stats-title {
  margin-bottom: 12rpx;
  color: #7a8c68;
  font-size: 24rpx;
  font-weight: 700;
}

.stat-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 58rpx;
}

.stat-row > view:first-child {
  min-width: 0;
  flex: 1;
}

.stat-label {
  min-width: 0;
  color: #2b2520;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.35;
}

.stat-count {
  margin-top: 4rpx;
  color: #8a7663;
  font-size: 22rpx;
}

.stat-amount {
  color: #2f6f62;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.3;
  text-align: right;
  flex-shrink: 0;
}

.option-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 14rpx;
}

.payer-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.option-chip {
  box-sizing: border-box;
  min-height: 62rpx;
  padding: 12rpx;
  border: 1rpx solid #eadfd1;
  border-radius: 14rpx;
  background: #fffdf9;
  color: #6f6255;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.25;
  text-align: center;
}

.option-chip.active {
  border-color: #2f6f62;
  background: #eaf4e7;
  color: #2f6f62;
}

.expense-card {
  margin-bottom: 18rpx;
}

.expense-main {
  min-width: 0;
  flex: 1;
}

.amount {
  min-width: 132rpx;
  color: #2f6f62;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: right;
  flex-shrink: 0;
}
