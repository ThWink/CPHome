<view class="page">
  <view class="title">记账</view>
  <view class="subtitle">{{statusText}}</view>

  <view class="section panel">
    <view class="label">金额</view>
    <input class="input" value="{{amountText}}" type="digit" bindinput="onAmountInput" placeholder="45.8" />
    <view class="field-gap">
      <view class="label">备注</view>
      <input class="input" value="{{note}}" bindinput="onNoteInput" placeholder="晚饭外卖" />
    </view>
    <button class="button action-gap" bindtap="createExpense">记一笔外卖</button>
  </view>

  <view class="section">
    <view wx:for="{{expenses}}" wx:key="id" class="panel expense-card">
      <view class="row">
        <view>
          <view class="label">{{item.occurredOn}} · {{item.categoryText}}</view>
          <view class="value">{{item.note}}</view>
        </view>
        <view class="amount">¥{{item.amountText}}</view>
      </view>
    </view>
  </view>
</view>
