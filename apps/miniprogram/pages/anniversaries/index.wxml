<view class="page">
  <view class="title">纪念日</view>
  <view class="subtitle">{{statusText}}</view>

  <view class="section panel">
    <view class="label">名称</view>
    <input class="input" value="{{title}}" bindinput="onTitleInput" placeholder="比如 在一起纪念日" />

    <view class="field-gap">
      <view class="label">日期</view>
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view class="input picker-input">{{date}}</view>
      </picker>
    </view>

    <view class="field-gap">
      <view class="label">重复</view>
      <view class="repeat-grid">
        <view
          wx:for="{{repeatOptions}}"
          wx:key="value"
          data-repeat="{{item.value}}"
          bindtap="selectRepeat"
          class="repeat-chip {{selectedRepeat === item.value ? 'active' : ''}}"
        >{{item.label}}</view>
      </view>
    </view>

    <view class="field-gap">
      <view class="label">提前提醒天数</view>
      <input class="input" value="{{remindDaysBeforeText}}" type="number" bindinput="onRemindInput" placeholder="7" />
    </view>

    <button class="button action-gap" bindtap="createAnniversary">保存纪念日</button>
  </view>

  <view class="section">
    <view wx:for="{{anniversaries}}" wx:key="id" class="panel anniversary-card">
      <view class="label">{{item.nextOn}} · {{item.repeatText}}</view>
      <view class="value">{{item.title}}</view>
      <view class="subtitle">还有 {{item.daysLeft}} 天 · 提前 {{item.remindDaysBefore}} 天提醒</view>
    </view>
  </view>
</view>
