.field-gap {
  margin-top: 22rpx;
}

.action-gap {
  margin-top: 24rpx;
}

.anniversary-card {
  margin-bottom: 18rpx;
  border-color: #f0c9bd;
  background: #fffaf7;
}

.anniversary-card .value {
  color: #7a3d2d;
}

.repeat-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 14rpx;
}

.repeat-chip {
  box-sizing: border-box;
  min-height: 62rpx;
  padding: 0 12rpx;
  border: 1rpx solid #eadfd1;
  border-radius: 14rpx;
  background: #fffdf9;
  color: #6f6255;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 62rpx;
  text-align: center;
}

.repeat-chip.active {
  border-color: #d8785f;
  background: #fff0ea;
  color: #9a4d38;
}

.picker-input {
  min-height: 76rpx;
  line-height: 36rpx;
}
