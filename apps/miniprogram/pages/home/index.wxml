<view class="page">
  <view class="row">
    <view>
      <view class="title">两人小家</view>
      <view class="subtitle">今天也把小日子过稳一点</view>
    </view>
    <view class="pill" bindtap="goSettings">设置</view>
  </view>

  <view class="hero-panel">
    <view class="hero-title">今天的小日子，刚刚好</view>
    <view class="hero-note">{{heroText}}</view>
    <view class="quick-grid">
      <view class="quick-tile" bindtap="goMeals">
        <view class="quick-tile-title">今晚吃什么</view>
        <view class="quick-tile-text">{{mealText}}</view>
      </view>
      <view class="quick-tile" bindtap="goAssistant">
        <view class="quick-tile-title">AI 小管家</view>
        <view class="quick-tile-text">问问今天有什么事</view>
      </view>
      <view class="quick-tile" bindtap="goWater">
        <view class="quick-tile-title">喝水</view>
        <view class="quick-tile-text">{{waterText}}</view>
      </view>
      <view class="quick-tile" bindtap="goParcels">
        <view class="quick-tile-title">快递</view>
        <view class="quick-tile-text">{{parcelText}}</view>
      </view>
    </view>
  </view>

  <view class="section panel">
    <view class="row">
      <view class="row-main">
        <view class="label">本地服务</view>
        <view class="value">{{readyText}}</view>
        <view class="subtitle">{{setupText}}</view>
      </view>
      <button class="button secondary" bindtap="goSetup">{{setupConfigured ? "查看" : "去绑定"}}</button>
    </view>
  </view>

  <view class="section">
    <view class="panel" bindtap="goWeather">
      <view class="row">
        <view class="row-main">
          <view class="label">天气</view>
          <view class="value">{{weatherText}}</view>
        </view>
        <button class="button secondary">查看</button>
      </view>
    </view>
    <view class="panel card-gap">
      <view class="row">
        <view class="row-main">
          <view class="label">喝水</view>
          <view class="value">{{waterText}}</view>
        </view>
        <button class="button secondary" bindtap="goWater">进入</button>
      </view>
    </view>
    <view class="panel card-gap">
      <view class="row">
        <view class="row-main">
          <view class="label">待办</view>
          <view class="value">{{todoText}}</view>
        </view>
        <button class="button secondary" bindtap="goTodos">进入</button>
      </view>
    </view>
    <view class="panel card-gap">
      <view class="row">
        <view class="row-main">
          <view class="label">纪念日</view>
          <view class="value">{{anniversaryText}}</view>
        </view>
        <button class="button secondary" bindtap="goAnniversaries">进入</button>
      </view>
    </view>
    <view class="panel card-gap">
      <view class="row">
        <view class="row-main">
          <view class="label">快递</view>
          <view class="value">{{parcelText}}</view>
        </view>
        <button class="button secondary" bindtap="goParcels">进入</button>
      </view>
    </view>
    <view class="panel card-gap">
      <view class="row">
        <view class="row-main">
          <view class="label">记账</view>
          <view class="value">{{expenseText}}</view>
        </view>
        <button class="button secondary" bindtap="goExpenses">进入</button>
      </view>
    </view>
  </view>

  <view class="section panel">
    <view class="label">今天的时间线</view>
    <view wx:for="{{timeline}}" wx:key="*this" class="timeline-item">{{item}}</view>
  </view>
</view>
