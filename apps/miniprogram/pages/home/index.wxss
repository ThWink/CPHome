.card-gap {
  margin-top: 18rpx;
}

.row-main {
  min-width: 0;
  flex: 1;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  margin-top: 18rpx;
  padding-left: 18rpx;
  border-left: 4rpx solid #2f6f62;
}

.timeline-time {
  box-sizing: border-box;
  min-width: 96rpx;
  max-width: 150rpx;
  min-height: 48rpx;
  padding: 6rpx 10rpx;
  border-radius: 8rpx;
  background: #e7f1e7;
  color: #2f6f62;
  font-size: 22rpx;
  line-height: 1.45;
  text-align: center;
  flex-shrink: 0;
  overflow-wrap: anywhere;
}

.timeline-text {
  min-width: 0;
  flex: 1;
  color: #3b352e;
  font-size: 28rpx;
  line-height: 1.5;
  overflow-wrap: anywhere;
}
