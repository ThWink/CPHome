.field-gap {
  margin-top: 22rpx;
}

.action-gap {
  margin-top: 24rpx;
}

.todo-card {
  margin-bottom: 18rpx;
  border-color: #d8e2dc;
}

.todo-card .value {
  color: #273f36;
}

.assignee-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 14rpx;
}

.assignee-chip {
  box-sizing: border-box;
  min-height: 92rpx;
  padding: 18rpx;
  border: 1rpx solid #eadfd1;
  border-radius: 14rpx;
  background: #fffdf9;
  color: #6f6255;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.5;
  text-align: center;
  overflow-wrap: anywhere;
}

.assignee-chip.active {
  border-color: #2f6f62;
  background: #eaf4e7;
  color: #2f6f62;
}

.picker-input {
  display: flex;
  align-items: center;
  min-height: 104rpx;
  line-height: 1.5;
}
