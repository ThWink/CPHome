.field-gap,
.action-gap {
  margin-top: 22rpx;
}

.owner-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 14rpx;
}

.owner-chip {
  box-sizing: border-box;
  min-height: 92rpx;
  padding: 18rpx;
  border: 1rpx solid #eadfd1;
  border-radius: 14rpx;
  background: #fffdf9;
  color: #6f6255;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.5;
  text-align: center;
  overflow-wrap: anywhere;
}

.owner-chip.active {
  border-color: #2f6f62;
  background: #eaf4e7;
  color: #2f6f62;
}

.parcel-card {
  margin-bottom: 18rpx;
}

.image-picker {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 14rpx;
}

.picker-button {
  min-width: 212rpx;
  min-height: 98rpx;
  padding: 18rpx 20rpx;
  font-size: 25rpx;
  line-height: 1.5;
}

.image-tip {
  min-width: 0;
  flex: 1;
  color: #7b6b5b;
  font-size: 24rpx;
  line-height: 1.45;
  overflow-wrap: anywhere;
}

.image-preview {
  margin-top: 18rpx;
}

.selected-image,
.parcel-image {
  display: block;
  width: 100%;
  height: 300rpx;
  border: 1rpx solid #eadfd1;
  border-radius: 16rpx;
  background: #efe7dc;
}

.remove-image-button {
  width: 100%;
  min-height: 88rpx;
  margin-top: 12rpx;
  padding: 16rpx 18rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.parcel-image {
  margin-bottom: 18rpx;
}

.parcel-row {
  align-items: stretch;
  flex-wrap: wrap;
}

.row-main {
  min-width: 0;
  flex: 1;
}

.parcel-actions {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  width: 100%;
  flex: 1 1 100%;
}

.action-button {
  width: auto;
  min-width: 0;
  flex: 1 1 0;
  min-height: 88rpx;
  padding: 16rpx 18rpx;
  font-size: 24rpx;
  line-height: 1.5;
}
