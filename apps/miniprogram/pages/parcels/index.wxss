.field-gap,
.action-gap {
  margin-top: 22rpx;
}

.owner-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 14rpx;
}

.owner-chip {
  box-sizing: border-box;
  min-height: 62rpx;
  padding: 0 12rpx;
  border: 1rpx solid #eadfd1;
  border-radius: 14rpx;
  background: #fffdf9;
  color: #6f6255;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 62rpx;
  text-align: center;
}

.owner-chip.active {
  border-color: #2f6f62;
  background: #eaf4e7;
  color: #2f6f62;
}

.parcel-card {
  margin-bottom: 18rpx;
}

.parcel-row {
  align-items: stretch;
}

.row-main {
  min-width: 0;
  flex: 1;
}

.parcel-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  width: 132rpx;
}

.action-button {
  width: 132rpx;
  height: 62rpx;
  padding: 0;
  line-height: 62rpx;
}
