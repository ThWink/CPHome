<view class="page">
  <view class="title">快递</view>
  <view class="subtitle">{{statusText}}</view>

  <view class="section panel">
    <view class="label">快递截图</view>
    <view class="image-picker">
      <button class="button secondary picker-button" bindtap="chooseParcelImage">选择截图或拍照</button>
      <view class="image-tip">有截图就可以直接发布，文字信息可选补充。</view>
    </view>

    <view wx:if="{{parcelImageLocalPath}}" class="image-preview">
      <image class="selected-image" src="{{parcelImageLocalPath}}" mode="aspectFill" bindtap="previewSelectedImage" />
      <button class="button soft remove-image-button" bindtap="clearParcelImage">移除截图</button>
    </view>

    <view class="field-gap">
      <view class="label">快递名</view>
      <input class="input" value="{{title}}" bindinput="onTitleInput" placeholder="可选，比如 京东快递" />
    </view>

    <view class="field-gap">
      <view class="label">取件码</view>
      <input class="input" value="{{pickupCode}}" bindinput="onPickupCodeInput" placeholder="可选，截图里有可不填" />
    </view>

    <view class="field-gap">
      <view class="label">位置</view>
      <input class="input" value="{{location}}" bindinput="onLocationInput" placeholder="可选，比如 楼下驿站" />
    </view>

    <view class="field-gap">
      <view class="label">归属</view>
      <view class="owner-grid">
        <view
          wx:for="{{ownerOptions}}"
          wx:key="value"
          data-owner="{{item.value}}"
          bindtap="selectOwner"
          class="owner-chip {{selectedOwner === item.value ? 'active' : ''}}"
        >{{item.label}}</view>
      </view>
    </view>

    <view class="field-gap">
      <view class="label">备注</view>
      <input class="input" value="{{note}}" bindinput="onNoteInput" placeholder="下班顺手拿、冷藏件" />
    </view>

    <button class="button action-gap" bindtap="createParcel">发布快递</button>
  </view>

  <view class="section">
    <view wx:for="{{parcels}}" wx:key="id" class="panel parcel-card">
      <image
        wx:if="{{item.imageUrl}}"
        class="parcel-image"
        src="{{item.imageUrl}}"
        mode="aspectFill"
        data-image="{{item.imageUrl}}"
        bindtap="previewParcelImage"
      />
      <view class="row parcel-row">
        <view class="row-main">
          <view class="label">{{item.location}} · {{item.ownerText}}</view>
          <view class="value">{{item.title}}</view>
          <view class="subtitle">取件码 {{item.pickupCode}}{{item.note ? " · " + item.note : ""}}</view>
        </view>
        <view class="parcel-actions">
          <button class="button secondary action-button" data-id="{{item.id}}" bindtap="markPicked">已取</button>
          <button class="button soft action-button" data-id="{{item.id}}" bindtap="cancelParcel">取消</button>
        </view>
      </view>
    </view>
  </view>
</view>
