.meal-card {
  margin-bottom: 18rpx;
}

.badge {
  min-width: 0;
  max-width: 45%;
  min-height: 72rpx;
  padding: 14rpx 18rpx;
  border-radius: 8rpx;
  background: #efe7dc;
  color: #6c5c4c;
  font-size: 24rpx;
  line-height: 1.5;
  text-align: center;
  overflow-wrap: anywhere;
}

.action-gap {
  margin-top: 20rpx;
}

.field-gap {
  margin-top: 20rpx;
}

.half {
  flex: 1 1 240rpx;
  min-width: 220rpx;
}

.row.action-gap {
  flex-wrap: wrap;
}

.preview {
  margin-top: 22rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #e1d7ca;
}

.request-title {
  font-size: 28rpx;
}

.small-button {
  min-width: 0;
  min-height: 88rpx;
  max-width: 156rpx;
  padding: 16rpx 18rpx;
  line-height: 1.5;
}

.request-row {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #e1d7ca;
  flex-wrap: wrap;
}

.request-main {
  min-width: 0;
  flex: 1;
}

.request-actions {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  width: 100%;
  flex: 1 1 100%;
}

.action-button {
  width: auto;
  min-width: 0;
  flex: 1 1 0;
  min-height: 88rpx;
  padding: 16rpx 18rpx;
  font-size: 24rpx;
  line-height: 1.5;
}
