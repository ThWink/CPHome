<view class="page">
  <view class="title">设置</view>
  <view class="subtitle">连接你部署在电脑、香橙派或服务器上的后端</view>

  <view class="section panel">
    <view class="label">后端地址</view>
    <input class="input" value="{{apiBaseUrl}}" bindinput="onApiInput" placeholder="http://192.168.1.10:3000" />
    <button class="button action-gap" bindtap="saveApiBaseUrl">保存地址</button>
  </view>

  <view class="section panel">
    <view class="label">访问 Token</view>
    <input class="input" password value="{{apiToken}}" bindinput="onApiTokenInput" placeholder="和后端 API_TOKEN 保持一致" />
    <view class="hint">本地开发可留空；部署到香橙派时建议填写。</view>
    <button class="button action-gap" bindtap="saveApiToken">保存 Token</button>
  </view>

  <view class="section panel">
    <view class="label">健康检查</view>
    <view class="value">{{healthText}}</view>
    <button class="button secondary action-gap" bindtap="checkHealth">检查后端</button>
  </view>

  <view class="section panel">
    <view class="label">本地数据备份</view>
    <view class="value">{{backupText}}</view>
    <view class="hint">导出内容会复制到剪贴板，包含本实例的业务数据，迁移前可以先保存。</view>
    <button class="button secondary action-gap" bindtap="copyBackup">复制备份 JSON</button>
  </view>

  <view class="section panel">
    <view class="label">恢复本地数据</view>
    <view class="value">{{restoreText}}</view>
    <textarea
      class="backup-editor"
      value="{{backupImportText}}"
      bindinput="onBackupImportInput"
      maxlength="-1"
      placeholder="粘贴备份 JSON"
    />
    <input
      class="input action-gap"
      value="{{restoreConfirmText}}"
      bindinput="onRestoreConfirmInput"
      placeholder="输入 RESTORE_LOCAL_DATA"
    />
    <button class="button danger action-gap" bindtap="restoreBackup">恢复备份</button>
  </view>

  <view class="section">
    <view class="row">
      <view>
        <view class="label">AI 记忆</view>
        <view class="value">{{memoryText}}</view>
      </view>
      <button class="button secondary compact-button" bindtap="loadMemoryData">刷新</button>
    </view>
  </view>

  <view class="section">
    <view wx:if="{{memories.length === 0}}" class="panel">
      <view class="label">饮食记忆</view>
      <view class="subtitle">还没有保存过饮食记忆</view>
    </view>

    <view wx:for="{{memories}}" wx:key="id" class="panel memory-card">
      <view class="row">
        <view class="memory-main">
          <view class="label">{{item.meal.occurredOn}}</view>
          <view class="value">{{item.itemText}}</view>
          <view wx:if="{{editingMemoryId !== item.id}}" class="subtitle">{{item.content}}</view>
          <textarea
            wx:else
            class="memory-editor"
            value="{{editingMemoryText}}"
            bindinput="onMemoryEditInput"
            maxlength="300"
            auto-height
          />
        </view>
        <view wx:if="{{editingMemoryId === item.id}}" class="memory-actions">
          <button class="button compact-button" bindtap="saveMemory">保存</button>
          <button class="button secondary compact-button" bindtap="cancelEditMemory">取消</button>
        </view>
        <view wx:else class="memory-actions">
          <button class="button secondary compact-button" data-id="{{item.id}}" data-content="{{item.content}}" bindtap="startEditMemory">编辑</button>
          <button class="button secondary compact-button" data-id="{{item.id}}" bindtap="deleteMemory">删除</button>
        </view>
      </view>
    </view>
  </view>

  <view class="section panel">
    <view class="label">口味偏好</view>
    <view wx:if="{{preferences.length === 0}}" class="subtitle">还没有偏好数据</view>
    <view wx:for="{{preferences}}" wx:key="id" class="preference-row">
      <view>
        <view class="preference-title">{{item.value}}</view>
        <view class="subtitle">{{item.note || "来自饮食记忆"}}</view>
      </view>
      <view class="preference-pill">{{item.sentimentText}}</view>
    </view>
  </view>
</view>
