<view class="page">
  <view class="title">设置</view>
  <view class="subtitle">连接你部署在电脑、香橙派或服务器上的后端</view>

  <view class="section panel">
    <view class="label">后端地址</view>
    <input class="input" value="{{apiBaseUrl}}" bindinput="onApiInput" placeholder="http://192.168.1.10:3000" />
    <button class="button action-gap" bindtap="saveApiBaseUrl">保存地址</button>
  </view>

  <view class="section panel">
    <view class="label">健康检查</view>
    <view class="value">{{healthText}}</view>
    <button class="button secondary action-gap" bindtap="checkHealth">检查后端</button>
  </view>
</view>
