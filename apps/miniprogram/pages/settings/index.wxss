.action-gap {
  margin-top: 20rpx;
}

.hint {
  margin-top: 12rpx;
  color: #8a7663;
  font-size: 24rpx;
  line-height: 1.45;
}

.compact-button {
  min-width: 0;
  min-height: 88rpx;
  padding: 16rpx 18rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.memory-card {
  margin-top: 18rpx;
}

.memory-main {
  min-width: 0;
  flex: 1;
}

.memory-actions {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  width: 100%;
  flex: 1 1 100%;
}

.memory-editor {
  box-sizing: border-box;
  width: 100%;
  min-height: 180rpx;
  margin-top: 12rpx;
  padding: 22rpx;
  border: 1rpx solid #e4d6c6;
  border-radius: 12rpx;
  background: #fffdf8;
  color: #2b2520;
  font-size: 26rpx;
  line-height: 1.5;
  overflow-wrap: anywhere;
}

.backup-editor {
  box-sizing: border-box;
  width: 100%;
  min-height: 280rpx;
  margin-top: 18rpx;
  padding: 22rpx;
  border: 1rpx solid #e4d6c6;
  border-radius: 12rpx;
  background: #fffdf8;
  color: #2b2520;
  font-size: 24rpx;
  line-height: 1.5;
  overflow-wrap: anywhere;
}

.danger {
  background: #9f3f35;
  color: #fffaf2;
}

.setting-meta-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-top: 14rpx;
  flex-wrap: wrap;
}

.setting-meta-label {
  flex: 0 0 72rpx;
  color: #8a7663;
  font-size: 24rpx;
  line-height: 1.45;
}

.setting-meta-value {
  min-width: 0;
  flex: 1 1 280rpx;
  color: #2b2520;
  font-size: 24rpx;
  line-height: 1.45;
  overflow-wrap: anywhere;
}

.preference-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #efe4d8;
  flex-wrap: wrap;
}

.preference-row:last-child {
  border-bottom: 0;
}

.preference-row > view:first-child {
  min-width: 0;
  flex: 1 1 240rpx;
}

.preference-title {
  color: #2b2520;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
}

.preference-pill {
  min-width: 0;
  max-width: 160rpx;
  min-height: 72rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #eef5ed;
  color: #2f6f62;
  font-size: 24rpx;
  line-height: 1.5;
  text-align: center;
  flex-shrink: 0;
  overflow-wrap: anywhere;
}
