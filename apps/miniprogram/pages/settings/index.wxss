.action-gap {
  margin-top: 20rpx;
}

.hint {
  margin-top: 12rpx;
  color: #8a7663;
  font-size: 24rpx;
  line-height: 1.45;
}

.compact-button {
  min-width: 112rpx;
  height: 60rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
  line-height: 60rpx;
}

.memory-card {
  margin-top: 18rpx;
}

.memory-main {
  min-width: 0;
  flex: 1;
}

.memory-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
}

.memory-editor {
  box-sizing: border-box;
  width: 100%;
  min-height: 132rpx;
  margin-top: 12rpx;
  padding: 18rpx;
  border: 1rpx solid #e4d6c6;
  border-radius: 12rpx;
  background: #fffdf8;
  color: #2b2520;
  font-size: 26rpx;
  line-height: 1.5;
}

.preference-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #efe4d8;
}

.preference-row:last-child {
  border-bottom: 0;
}

.preference-title {
  color: #2b2520;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
}

.preference-pill {
  min-width: 96rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #eef5ed;
  color: #2f6f62;
  font-size: 24rpx;
  text-align: center;
  white-space: nowrap;
}
