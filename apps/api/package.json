{
  "name": "@couple-life/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "corepack pnpm --filter @couple-life/shared build && tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "seed:demo": "tsx src/dev/seed-demo.ts",
    "start": "node dist/index.js",
    "test": "corepack pnpm --filter @couple-life/shared build && vitest run",
    "typecheck": "corepack pnpm --filter @couple-life/shared build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@couple-life/shared": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "drizzle-orm": "^0.38.4",
    "fastify": "^5.2.1",
    "nanoid": "^5.0.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
